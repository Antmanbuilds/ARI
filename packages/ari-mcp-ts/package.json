{
  "name": "ari-mcp",
  "version": "0.2.0",
  "description": "MCP server that stops AI agents from overpaying. Drops into Claude Desktop, Cursor, Continue, Windsurf, Zed, ChatGPT desktop, and Gemini CLI to give any agent live fair-market-value lookups, a green/amber/red prepay verdict, and cryptographically-signed (Ed25519) receipts for every x402 / MPP / agentic-payment quote.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist-cjs/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "require": "./dist-cjs/tools/index.js"
    }
  },
  "bin": {
    "ari-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "dist-cjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate:version": "node scripts/generate-version.mjs",
    "build": "node scripts/generate-version.mjs && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist-cjs/package.json', JSON.stringify({type:'commonjs'}))\" && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "test": "node --import tsx --test test/*.test.ts",
    "test:integration": "node tests/integration.test.js",
    "ship:check": "node ../../scripts/ship-check.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "publish:npm": "pnpm publish --access public --no-git-checks",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ari",
    "agentic-rate-indicators",
    "x402",
    "http-402",
    "mpp",
    "machine-payments",
    "fair-price",
    "fair-market-value",
    "fmv",
    "price-oracle",
    "signed-receipts",
    "ed25519",
    "agentic-payments",
    "agent-wallet",
    "ai-agents",
    "ai-payments",
    "llm-tools",
    "llm-agent",
    "anthropic",
    "claude",
    "claude-desktop",
    "cursor",
    "continue",
    "windsurf",
    "zed",
    "gemini",
    "openai",
    "chatgpt",
    "langchain",
    "langgraph",
    "llamaindex",
    "vercel-ai-sdk",
    "pydantic-ai",
    "coinbase",
    "stripe",
    "tempo"
  ],
  "homepage": "https://agentrateindicators.com/docs/mcp",
  "bugs": {
    "url": "https://github.com/Antmanbuilds/ARI/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Antmanbuilds"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Antmanbuilds/ARI.git",
    "directory": "tools/ari-mcp-ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@noble/ed25519": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "^5.9.0"
  }
}
