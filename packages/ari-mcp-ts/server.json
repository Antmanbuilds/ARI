{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.Antmanbuilds/ari-mcp",
  "description": "Fair-price checks, leaderboards, and Ed25519 receipt verification for x402/MPP services.",
  "status": "active",
  "repository": {
    "url": "https://github.com/Antmanbuilds/ARI",
    "source": "github",
    "subfolder": "packages/ari-mcp-ts"
  },
  "version": "0.1.3",
  "websiteUrl": "https://agentrateindicators.com/docs/mcp",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "ari-mcp",
      "version": "0.1.3",
      "transport": { "type": "stdio" },
      "runtimeHint": "npx",
      "environmentVariables": [
        {
          "name": "ARI_API_BASE_URL",
          "description": "Override the ARI API base URL. Defaults to https://agentrateindicators.com/api.",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ]
}
